# Base de la API. En desarrollo se deja vacio/por defecto (/api con proxy de Vite).
# En produccion apunta al backend, ej:
# VITE_API_BASE=http://localhost:8000/api

# Modo ChatGPT (helper). SIN claves de API: usa la sesion del navegador.
# chatgpt.com BLOQUEA cargarse en iframes (politica de OpenAI), por eso el
# iframe esta desactivado por defecto y el flujo es copiar prompt -> abrir
# en pestaña nueva. Activalo solo si usas una URL que SI permita embebido.
VITE_CHATGPT_IFRAME_URL=https://chatgpt.com/
VITE_ENABLE_CHATGPT_IFRAME=false
VITE_CHATGPT_IFRAME_FALLBACK_NEW_TAB=true

# Diagnostico de la auto-deteccion de canales (R/R). Con "true" se loguea en
# la consola del navegador por que se acepta/rechaza cada par de lineas.
VITE_CHANNEL_RR_DEBUG=false
