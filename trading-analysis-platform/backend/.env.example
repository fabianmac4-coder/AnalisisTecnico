# SQL Server (Windows Authentication / Trusted Connection)
DB_SERVER=LAPTOP-HIR7OVRK\SQLEXPRESS
DB_NAME=AnalisisTecnico
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_TRUSTED_CONNECTION=yes
DB_TRUST_CERT=yes

# JWT (genera un secreto fuerte: python -c "import secrets; print(secrets.token_urlsafe(48))")
JWT_SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# URL del frontend (links de set/reset password en los correos)
FRONTEND_URL=http://localhost:5174

# SMTP (vacio = modo desarrollo: no envia correo, loguea el link en consola)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Trading Analysis Platform
SMTP_FROM_EMAIL=

# OpenAI (chat de IA). La clave SOLO vive en el backend.
# Vacio => el chat responde "IA no disponible" sin romper la app.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_OUTPUT_TOKENS=1200
OPENAI_ENABLE_STREAMING=true

# Limites del chat de IA (costo / abuso)
AI_CHAT_MAX_MESSAGES_PER_MINUTE=10
AI_CHAT_MAX_CONTEXT_MESSAGES=20
AI_CHAT_MAX_DRAWINGS_CONTEXT=50
AI_CHAT_MAX_NEWS_ITEMS=5

# --- Macro Dashboard (Fase 3) — todas OPCIONALES ---
# Sin FRED_API_KEY los indicadores de EE.UU. salen como "Unavailable" (la pagina
# no falla). Clave gratuita: https://fredaccount.stlouisfed.org/apikeys
ENABLE_MACRO_DASHBOARD=true
MACRO_CACHE_TTL_MINUTES=60
MACRO_DEBUG=false
FRED_API_KEY=
FRED_API_BASE_URL=https://api.stlouisfed.org/fred
# Indicadores de actividad real (reemplazan a los ISM PMI, descontinuados gratis
# en FRED): produccion industrial (INDPRO) y ventas minoristas (RSAFS).
FRED_SERIES_INDUSTRIAL_PRODUCTION=INDPRO
FRED_SERIES_RETAIL_SALES=RSAFS
# Calendario economico: con FRED_API_KEY se arma con las fechas de release de FRED;
# sin clave o sin datos utiles, la seccion se OCULTA (no se muestra un panel vacio).
ECONOMIC_CALENDAR_PROVIDER=
ECONOMIC_CALENDAR_API_KEY=
ECONOMIC_CALENDAR_TTL_MINUTES=120
